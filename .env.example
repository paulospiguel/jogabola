# Drizzle / PostgreSQL
DATABASE_URL="postgresql://<user>:<password>@<url>:<port>/<db_name>"

# Better Auth
BETTER_AUTH_SECRET=""

# GOOGLE
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (optional; all five values are required to enable it)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Passkey relying party hostname override (optional)
PASSKEY_RP_ID=

# Additional trusted origins, comma-separated (optional)
TRUSTED_ORIGINS=

# App URLs
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public main domain override (optional)
NEXT_PUBLIC_MAIN_DOMAIN=

RESEND_API_KEY=
EMAIL_FROM="JogaBola <noreply@resend.dev>"

NEXT_PUBLIC_IS_BETA=true
APP_LAUNCHED=false

NOTION_API_KEY=
NOTION_WAITLIST_DATA_SOURCE_ID=

R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=jogabola-proofs
R2_PUBLIC_URL=https://pub-<YOUR_HASH>.r2.dev

# Ably (real-time event chat)
ABLY_API_KEY=

# Statsig analytics (client SDK)
NEXT_PUBLIC_STATSIG_CLIENT_KEY=
STATSIG_SERVER_SECRET_KEY=

# Vercel cron authentication
CRON_SECRET=
