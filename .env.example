#Prisma
DATABASE_URL="postgresql://<user>:<password>@<url>:<port>/<db_name>"

#Authjs
AUTH_SECRET=""
AUTH_LOGIN_REDIRECT=/

# GOOGLE
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GITHUB
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# App URLs
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend email
# For quick local tests, `JogaBola <noreply@resend.dev>` can only send to the
# email address that owns the Resend account. To send to athletes/guests, verify
# a domain in Resend and use an address from that domain.
RESEND_API_KEY=
EMAIL_FROM="JogaBola <noreply@resend.dev>"
# Example after domain verification:
# EMAIL_FROM="JogaBola <noreply@jogabola.app>"

# Release flags
# Show "Beta" badge across the app
NEXT_PUBLIC_IS_BETA=true
# Set to "true" once the app is publicly launched.
# While "false", only tester emails in Notion can access protected routes.
APP_LAUNCHED=false

# Notion (waitlist + testers)
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=
# ID of the Notion database with columns: Name (title), Email (email), Type (select: "waitlist" | "tester")
NOTION_WAITLIST_DB_ID=

# ─── Cloudflare R2 (payment proof uploads) ────────────────────────────────
# Create a bucket at dash.cloudflare.com → R2 → Create bucket (name: jogabola-proofs)
# Create an R2 API token with "Object Read & Write" for that bucket.
#
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=jogabola-proofs
# Public URL: enable "Public access" on the bucket or use a Custom Domain.
# Example:  https://pub-<hash>.r2.dev   or   https://proofs.jogabola.app
R2_PUBLIC_URL=https://pub-<YOUR_HASH>.r2.dev
