{
	"name": "jogabola",
	"version": "1.0.0",
	"private": true,
	"workspaces": ["packages/*", "apps/*"],
	"scripts": {
		"build": "turbo build",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"dev": "turbo dev --parallel",
		"test": "turbo test --parallel",
		"start:dashboard": "turbo start --filter=@jogabola/dashboard",
		"start:website": "turbo start --filter=@jogabola/website",
		"dev:api": "turbo dev --filter=@jogabola/api",
		"dev:dashboard": "turbo dev --filter=@jogabola/dashboard",
		"build:dashboard": "turbo build --filter=@jogabola/dashboard",
		"dev:website": "turbo dev --filter=@jogabola/website ",
		"format": "biome format --write .",
		"lint": "turbo lint && manypkg check",
		"typecheck": "turbo typecheck"
	},
	"dependencies": {
		"@biomejs/biome": "1.8.3",
		"@manypkg/cli": "^0.21.4",
		"typescript": "^5.5.4"
	},
	"devDependencies": {
		"turbo": "2.0.14"
	},
	"resolutions": {
		"jackspeak": "2.1.1"
	},
  "packageManager": "bun@1.1.16"
}
