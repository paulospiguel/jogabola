datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
  PLAYER
  COACH
  MANAGER
  WATCHER
}

enum MatchStatus {
  Scheduled
  InProgress
  Finished
  Postponed
  Cancelled
}

enum CupStatus {
  Upcoming
  Ongoing
  Completed
  Cancelled
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  role                   UserRole? @default(USER)
  password               String?
  isTwoFactorAuthEnabled Boolean   @default(false)
  twoFactorAuthVerified  DateTime?
  accounts               Account[]
  team                   Team[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@id([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ResetPasswordToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Team {
  id                  String       @id @default(cuid())
  name                String       @unique
  slug                String       @unique
  bio                 String?
  logo                String?
  email               String       @unique
  location            String?
  language            String?
  manager             String?
  founded             DateTime?
  homeGround          String?
  teamShape           String?
  minRadiusPlayerArea Int?
  maxRadiusPlayerArea Int?
  minRadiusPlayerAge  Int?
  maxRadiusPlayerAge  Int?
  isPublic            Boolean      @default(true)
  isVerified          Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  cups                Cup[]
  teamMembers         TeamMember[]
  user                User?        @relation(fields: [userId], references: [id])
  userId              String?

  // Relation for home team matches
  homeMatches Match[] @relation("HomeTeam")

  // Relation for away team matches
  awayMatches    Match[]          @relation("AwayTeam")
  TeamStatistics TeamStatistics[]
}

model TeamMember {
  id       String    @id @default(cuid())
  role     UserRole?
  teamId   String
  userId   String
  playerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team    @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])
}

model Player {
  id         String    @id @default(cuid())
  name       String
  bio        String?
  image      String?
  location   String?
  birth_date DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  teamMembers TeamMember[]
}

model Cup {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  startDate DateTime
  endDate   DateTime?
  location  String    @db.VarChar(255)
  status    CupStatus
  matches   Match[]   @relation("CupMatches")
  team      Team?     @relation(fields: [teamId], references: [id])
  teamId    String?
}

model Match {
  id            Int         @id @default(autoincrement())
  matchDate     DateTime
  matchTime     DateTime
  stadium       String      @db.VarChar(255)
  homeTeamScore Int?
  awayTeamScore Int?
  matchStatus   MatchStatus
  cupId         Int? // Relation field to Cup

  cup        Cup?   @relation("CupMatches", fields: [cupId], references: [id])
  homeTeamId String
  awayTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
}

model TeamStatistics {
  id             Int @id @default(autoincrement())
  position       Int // The team's position in the league or tournament
  played         Int // Number of matches played
  won            Int // Number of matches won
  drawn          Int // Number of matches drawn
  lost           Int // Number of matches lost
  goalsFor       Int // Number of goals scored by the team
  goalsAgainst   Int // Number of goals conceded by the team
  goalDifference Int @default(0) // Calculated as goalsFor - goalsAgainst
  points         Int @default(0) // Points earned (e.g., 3 for a win, 1 for a draw)

  team   Team   @relation(fields: [teamId], references: [id]) // Link to the team
  teamId String // Foreign key to the Team model

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
